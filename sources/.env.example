# ============================================================
#  .env.example — 서버에서 nano .env 로 작성하는 파일
#  (이 파일은 서버 ~/brain-pipeline/.env 에 저장됩니다)
# ============================================================

# ── Anthropic (Claude) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-여기에입력

# ── OpenAI (GPT + TTS) ───────────────────────────────────
OPENAI_API_KEY=sk-여기에입력

# ── YouTube Data API v3 ──────────────────────────────────
YOUTUBE_CLIENT_ID=여기에입력.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=여기에입력
YOUTUBE_REFRESH_TOKEN=여기에입력

# ── PubMed (선택사항 — 없으면 속도 제한 3req/sec, 있으면 10req/sec) ──
PUBMED_API_KEY=

# ── Telegram 봇 알림 & 명령 수신 ─────────────────────────
TELEGRAM_BOT_TOKEN=여기에입력
TELEGRAM_CHAT_ID=여기에입력

# ── 파이프라인 설정 ──────────────────────────────────────
DEFAULT_LLM=anthropic
TTS_ENGINE=openai
VIDEO_ENGINE=remotion
CHANNEL_LANGUAGE=ko
